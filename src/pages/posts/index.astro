---
import { getEmDashCollection, getTermsForEntries } from "emdash";
import Base from "../../layouts/Base.astro";
import { getReadingTime } from "../../utils/reading-time";

const { entries: posts } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
});

const categoriesByEntry =
	posts.length > 0
		? await getTermsForEntries(
				"posts",
				posts.map((p) => p.data.id),
				"category",
			)
		: new Map();

function formatDate(date: Date | null | undefined): string {
	if (!date) return "";
	return date.toISOString().slice(0, 10).replace(/-/g, "·");
}

// Group posts by year for the archive view
type PostWithMeta = {
	post: (typeof posts)[number];
	category: { slug: string; label: string } | null;
};

const grouped = new Map<number, PostWithMeta[]>();

for (const post of posts) {
	const cats = categoriesByEntry.get(post.data.id);
	const category = cats && cats.length > 0 ? { slug: cats[0].slug, label: cats[0].label } : null;
	const year = post.data.publishedAt?.getFullYear() ?? 0;

	if (!grouped.has(year)) grouped.set(year, []);
	grouped.get(year)!.push({ post, category });
}

const years = [...grouped.keys()].sort((a, b) => b - a);
---

<Base title="Blog" description="All articles by Le Hoang Tin — SEO, AI search, case studies, and personal writing.">
	<div class="posts-page">
		<header class="page-header">
			<p class="page-kicker">Writing</p>
			<h1 class="page-title">All Articles</h1>
			<p class="page-description">
				{posts.length} {posts.length === 1 ? "article" : "articles"} on SEO, AI search, case studies, and more.
			</p>
		</header>

		{
			posts.length === 0 ? (
				<p class="empty">No posts yet.</p>
			) : (
				<div class="archive">
					{years.map((year) => (
						<div class="year-group">
							<h2 class="year-label">{year === 0 ? "Undated" : year}</h2>
							<div class="article-list" role="list">
								{grouped.get(year)!.map(({ post, category }) => (
									<a
										href={`/posts/${post.id}`}
										class="article-row"
										role="listitem"
									>
										<span class="article-num">
											{post.data.number != null ? `№ ${post.data.number}` : "—"}
										</span>
										<time class="article-date">
											{formatDate(post.data.publishedAt)}
										</time>
										{category ? (
											<span class="article-cat">{category.label}</span>
										) : (
											<span class="article-cat" />
										)}
										<span class="article-title-col">{post.data.title}</span>
										<span class="article-time">
											{getReadingTime(post.data.content)} min
										</span>
									</a>
								))}
							</div>
						</div>
					))}
				</div>
			)
		}
	</div>
</Base>

<style>
	.posts-page {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-16) var(--spacing-6) var(--spacing-24);
	}

	.page-header {
		max-width: 640px;
		margin-bottom: var(--spacing-16);
		padding-bottom: var(--spacing-10);
		border-bottom: 1px solid var(--color-border-subtle);
	}

	.page-kicker {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		letter-spacing: var(--tracking-wider);
		text-transform: uppercase;
		color: var(--color-amber);
		margin-bottom: var(--spacing-3);
	}

	.page-title {
		font-size: clamp(var(--font-size-3xl), 5vw, var(--font-size-5xl));
		font-weight: 700;
		font-style: italic;
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--spacing-3);
	}

	.page-description {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		color: var(--color-muted);
	}

	.empty {
		font-family: var(--font-sans);
		color: var(--color-muted);
	}

	.archive {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-12);
	}

	.year-label {
		font-family: var(--font-mono);
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		font-weight: 400;
		margin-bottom: var(--spacing-4);
		padding-bottom: var(--spacing-4);
		border-bottom: 1px solid var(--color-border-subtle);
	}

	.article-list {
		display: flex;
		flex-direction: column;
	}

	.article-row {
		display: grid;
		grid-template-columns: 3.5rem 7.5rem 6rem 1fr 4rem;
		align-items: baseline;
		gap: var(--spacing-4);
		padding: var(--spacing-4) 0;
		border-bottom: 1px solid var(--color-border-subtle);
		text-decoration: none;
		color: inherit;
		transition: background var(--transition-fast);
	}

	.article-row:last-child {
		border-bottom: none;
	}

	.article-row:hover {
		background: color-mix(in srgb, var(--color-accent) 5%, transparent);
	}

	.article-row:hover .article-title-col {
		color: var(--color-accent);
	}

	.article-num {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-muted);
		white-space: nowrap;
	}

	.article-date {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-muted);
		white-space: nowrap;
	}

	.article-cat {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
		color: var(--color-amber);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.article-title-col {
		font-size: var(--font-size-base);
		line-height: var(--leading-snug);
		color: var(--color-text);
		font-weight: 500;
		transition: color var(--transition-fast);
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.article-time {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-muted);
		text-align: right;
		white-space: nowrap;
	}

	/* Responsive */
	@media (max-width: 900px) {
		.article-row {
			grid-template-columns: 3rem 1fr auto;
			grid-template-rows: auto auto;
		}

		.article-num {
			grid-row: 1;
			grid-column: 1;
		}

		.article-title-col {
			grid-row: 1;
			grid-column: 2 / 4;
			white-space: normal;
		}

		.article-date {
			grid-row: 2;
			grid-column: 2;
		}

		.article-cat {
			grid-row: 2;
			grid-column: 3;
		}

		.article-time {
			display: none;
		}
	}

	@media (max-width: 600px) {
		.posts-page {
			padding: var(--spacing-8) var(--spacing-4) var(--spacing-16);
		}

		.article-row {
			grid-template-columns: 2.5rem 1fr;
			gap: var(--spacing-2) var(--spacing-3);
		}

		.article-date,
		.article-cat,
		.article-time {
			display: none;
		}

		.article-title-col {
			grid-column: 2;
			white-space: normal;
		}
	}
</style>
