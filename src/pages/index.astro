---
import {
	getEmDashCollection,
	getTermsForEntries,
	getSiteSettings,
} from "emdash";
import Base from "../layouts/Base.astro";
import { getReadingTime } from "../utils/reading-time";

const [{ entries: posts }, settings] = await Promise.all([
	getEmDashCollection("posts", {
		orderBy: { published_at: "desc" },
		limit: 7,
	}),
	getSiteSettings(),
]);

// Batch-fetch categories
const postIds = posts.map((p) => p.data.id);
const categoriesByEntry =
	postIds.length > 0
		? await getTermsForEntries("posts", postIds, "category")
		: new Map();

const featuredPost = posts[0] ?? null;
const listPosts = posts.slice(1);
const hasMorePosts = posts.length >= 7;

// Date → YYYY·MM·DD
function formatDate(date: Date | null | undefined): string {
	if (!date) return "";
	return date.toISOString().slice(0, 10).replace(/-/g, "·");
}

function getFirstCategory(entryDataId: string) {
	const cats = categoriesByEntry.get(entryDataId);
	return cats && cats.length > 0 ? cats[0] : null;
}
---

<Base title={settings.title ?? "Le Hoang Tin"} description={settings.tagline}>
	<div class="home">

		<!-- ── Hero ── -->
		<section class="hero">
			<div class="hero-inner">
				<div class="hero-text">
					<div class="hero-masthead">
						<span class="vol-badge">VOL. I</span>
						<span class="masthead-rule" aria-hidden="true"></span>
						<span class="city-label">HCMC, VN</span>
					</div>

					<h1 class="hero-name">Le Hoang Tin</h1>
					<p class="hero-role">SEO Specialist &amp; Content Strategist</p>

					<p class="hero-bio">
						Internet from Ho Chi Minh City.<br />
						3 years building organic growth at GTV SEO Agency.<br />
						I think about AI search, content strategy, and the future of SEO.
					</p>

					<div class="hero-ctas">
						{
							featuredPost && (
								<a href={`/posts/${featuredPost.id}`} class="cta-primary">
									Read latest article →
								</a>
							)
						}
						<a href="/rss.xml" class="cta-secondary">RSS ↗</a>
					</div>
				</div>

				<div class="hero-portrait">
					<div class="portrait-frame">
						<img
							src="/tin_le_hoang.jpg"
							alt="Le Hoang Tin — SEO Specialist, Ho Chi Minh City"
							class="portrait-img"
							width="200"
							height="200"
							loading="eager"
						/>
					</div>
					<p class="portrait-caption">FIG. 1 — THE AUTHOR, HCMC, 2025</p>
				</div>
			</div>
		</section>

		<!-- ── Info strip ── -->
		<section class="info-strip">
			<div class="info-inner">
				<div class="info-col">
					<h2 class="info-heading">Currently working on</h2>
					<ul class="info-list">
						<li>
							<span class="info-arrow">→</span>
							<span>GTV SEO — leading SEO strategy &amp; projects</span>
						</li>
						<li>
							<span class="info-arrow">→</span>
							<span>AI-driven content optimisation for ChatGPT / Claude / SGE</span>
						</li>
						<li>
							<span class="info-arrow">→</span>
							<span>Building this blog &amp; portfolio</span>
						</li>
					</ul>
				</div>

				<div class="info-col">
					<h2 class="info-heading">Elsewhere</h2>
					<ul class="info-list">
						<li>
							<span class="info-label">LinkedIn</span>
							<a
								href="https://www.linkedin.com/in/tin-le-hoang"
								target="_blank"
								rel="noopener noreferrer"
								class="info-link"
							>
								Tin Le Hoang ↗
							</a>
						</li>
						<li>
							<span class="info-label">Email</span>
							<a href="mailto:tinledoihoa@gmail.com" class="info-link">
								tinledoihoa@gmail.com
							</a>
						</li>
						<li>
							<span class="info-label">Phone</span>
							<a href="tel:+84357669476" class="info-link">0357.669.476</a>
						</li>
					</ul>
				</div>
			</div>
		</section>

		{
			posts.length > 0 && (
				<div class="content-area">

					{/* Featured post */}
					{featuredPost && (
						<section class="featured-section">
							<div class="featured-label-row">
								<span class="featured-label">Featured</span>
								<span class="featured-rule" aria-hidden="true" />
							</div>
							<a href={`/posts/${featuredPost.id}`} class="featured-card">
								<div class="featured-card-inner">
									<div class="featured-card-meta">
										{getFirstCategory(featuredPost.data.id) && (
											<span class="category-tag">
												{getFirstCategory(featuredPost.data.id)!.label}
											</span>
										)}
										{featuredPost.data.number != null && (
											<span class="article-num-badge">
												№ {featuredPost.data.number}
											</span>
										)}
									</div>
									<h2 class="featured-card-title">
										{featuredPost.data.title}
									</h2>
									{featuredPost.data.excerpt && (
										<p class="featured-card-excerpt">
											{featuredPost.data.excerpt}
										</p>
									)}
									<div class="featured-card-foot">
										{featuredPost.data.publishedAt && (
											<time class="article-date-mono">
												{formatDate(featuredPost.data.publishedAt)}
											</time>
										)}
										<span class="article-read-time">
											{getReadingTime(featuredPost.data.content)} min read
										</span>
										<span class="read-link">Read article →</span>
									</div>
								</div>
							</a>
						</section>
					)}

					{/* Numbered article list */}
					{listPosts.length > 0 && (
						<section class="articles-section">
							<header class="section-header">
								<h2 class="section-title">Recent articles</h2>
								{hasMorePosts && (
									<a href="/posts" class="section-link">
										See all →
									</a>
								)}
							</header>

							<div class="articles-list" role="list">
								{listPosts.map((post, idx) => {
									const cat = getFirstCategory(post.data.id);
									// Use stored number; fall back to position-based counter
									const num = post.data.number ?? (listPosts.length - idx);
									return (
										<a
											href={`/posts/${post.id}`}
											class="article-row"
											role="listitem"
										>
											<span class="article-num">№ {num}</span>
											<time class="article-date-mono">
												{formatDate(post.data.publishedAt)}
											</time>
											{cat ? (
												<span class="article-cat">{cat.label}</span>
											) : (
												<span class="article-cat" />
											)}
											<span class="article-title-col">
												{post.data.title}
											</span>
											<span class="article-time">
												{getReadingTime(post.data.content)} min
											</span>
										</a>
									);
								})}
							</div>

							{hasMorePosts && (
								<div class="see-all-row">
									<a href="/posts" class="see-all-link">
										See all articles →
									</a>
								</div>
							)}
						</section>
					)}
				</div>
			)
		}

		{
			posts.length === 0 && (
				<div class="empty-state">
					<p>No posts yet.</p>
					<a href="/_emdash/admin/content/posts/new" class="cta-primary">
						Create first post
					</a>
				</div>
			)
		}
	</div>
</Base>

<style>
	/* ── Layout ── */
	.home {
		max-width: var(--wide-width);
		margin: 0 auto;
	}

	/* ── Hero ── */
	.hero {
		padding: var(--spacing-20) var(--spacing-6) var(--spacing-16);
		border-bottom: 1px solid var(--color-border-subtle);
	}

	.hero-inner {
		display: flex;
		align-items: flex-start;
		gap: var(--spacing-16);
		max-width: 860px;
	}

	.hero-text {
		flex: 1;
		min-width: 0;
	}

	.hero-masthead {
		display: flex;
		align-items: center;
		gap: var(--spacing-4);
		margin-bottom: var(--spacing-10);
	}

	.vol-badge,
	.city-label {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		letter-spacing: var(--tracking-wider);
		text-transform: uppercase;
		color: var(--color-muted);
		white-space: nowrap;
	}

	.masthead-rule {
		flex: 1;
		height: 1px;
		background: var(--color-border);
	}

	.hero-name {
		font-size: clamp(3rem, 8vw, 5.5rem);
		font-weight: 900;
		font-style: italic;
		line-height: 1.0;
		letter-spacing: -0.04em;
		margin-bottom: var(--spacing-4);
		color: var(--color-text);
	}

	.hero-role {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		font-weight: 600;
		letter-spacing: var(--tracking-wider);
		text-transform: uppercase;
		color: var(--color-amber);
		margin-bottom: var(--spacing-6);
	}

	.hero-bio {
		font-size: var(--font-size-lg);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin-bottom: var(--spacing-8);
		max-width: 52ch;
	}

	.hero-ctas {
		display: flex;
		align-items: center;
		gap: var(--spacing-5);
		flex-wrap: wrap;
	}

	.cta-primary {
		display: inline-block;
		padding: var(--spacing-3) var(--spacing-6);
		background: var(--color-accent);
		color: var(--color-on-accent);
		text-decoration: none;
		border-radius: var(--radius);
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		font-weight: 500;
		transition: background var(--transition-fast);
	}

	.cta-primary:hover {
		background: var(--color-accent-hover);
		color: var(--color-on-accent);
	}

	.cta-secondary {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.cta-secondary:hover {
		color: var(--color-text);
	}

	/* ── Portrait ── */
	.hero-portrait {
		flex-shrink: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--spacing-3);
		padding-top: var(--spacing-12);
	}

	.portrait-frame {
		width: 200px;
		height: 200px;
		border-radius: 50%;
		overflow: hidden;
		border: 3px solid var(--color-border);
		background: var(--color-surface);
	}

	.portrait-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center top;
		display: block;
	}

	.portrait-caption {
		font-family: var(--font-mono);
		font-size: 0.625rem;
		letter-spacing: var(--tracking-wider);
		text-transform: uppercase;
		color: var(--color-muted);
		text-align: center;
		max-width: 200px;
		line-height: var(--leading-relaxed);
	}

	/* ── Info strip ── */
	.info-strip {
		border-bottom: 1px solid var(--color-border-subtle);
	}

	.info-inner {
		display: grid;
		grid-template-columns: 1fr 1fr;
	}

	.info-col {
		padding: var(--spacing-10) var(--spacing-6);
	}

	.info-col:first-child {
		border-right: 1px solid var(--color-border-subtle);
	}

	.info-heading {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wider);
		color: var(--color-muted);
		margin-bottom: var(--spacing-5);
	}

	.info-list {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: var(--spacing-3);
	}

	.info-list li {
		display: flex;
		align-items: baseline;
		gap: var(--spacing-3);
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
	}

	.info-arrow {
		color: var(--color-accent);
		flex-shrink: 0;
		font-size: var(--font-size-xs);
	}

	.info-label {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-muted);
		min-width: 4.5rem;
		flex-shrink: 0;
	}

	.info-link {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.info-link:hover {
		color: var(--color-accent);
	}

	/* ── Content area ── */
	.content-area {
		padding: var(--spacing-16) var(--spacing-6) var(--spacing-24);
		display: flex;
		flex-direction: column;
		gap: var(--spacing-16);
	}

	/* ── Featured post ── */
	.featured-label-row {
		display: flex;
		align-items: center;
		gap: var(--spacing-4);
		margin-bottom: var(--spacing-6);
	}

	.featured-label {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wider);
		color: var(--color-muted);
		white-space: nowrap;
	}

	.featured-rule {
		flex: 1;
		height: 1px;
		background: var(--color-border-subtle);
	}

	.featured-card {
		display: block;
		background: var(--color-bg-subtle);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		text-decoration: none;
		color: inherit;
		overflow: hidden;
		transition:
			border-color var(--transition-base),
			box-shadow var(--transition-base);
	}

	.featured-card:hover {
		border-color: var(--color-accent);
		box-shadow: 0 4px 24px color-mix(in srgb, var(--color-accent) 10%, transparent);
	}

	.featured-card-inner {
		padding: var(--spacing-10);
		max-width: 780px;
	}

	.featured-card-meta {
		display: flex;
		align-items: center;
		gap: var(--spacing-3);
		margin-bottom: var(--spacing-4);
	}

	.category-tag {
		display: inline-block;
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
		color: var(--color-on-accent);
		background: var(--color-accent);
		border-radius: var(--radius);
		padding: 2px var(--spacing-2);
	}

	.article-num-badge {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-muted);
	}

	.featured-card-title {
		font-size: clamp(var(--font-size-2xl), 3.5vw, var(--font-size-4xl));
		font-weight: 700;
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-tight);
		margin-bottom: var(--spacing-4);
		transition: color var(--transition-fast);
	}

	.featured-card:hover .featured-card-title {
		color: var(--color-accent);
	}

	.featured-card-excerpt {
		font-size: var(--font-size-lg);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin-bottom: var(--spacing-6);
		max-width: 60ch;
	}

	.featured-card-foot {
		display: flex;
		align-items: center;
		gap: var(--spacing-4);
		flex-wrap: wrap;
	}

	.article-date-mono,
	.article-read-time {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-muted);
	}

	.read-link {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		color: var(--color-accent);
		margin-left: auto;
	}

	/* ── Numbered article list ── */
	.section-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		margin-bottom: var(--spacing-6);
		padding-bottom: var(--spacing-4);
		border-bottom: 1px solid var(--color-border-subtle);
	}

	.section-title {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wider);
		color: var(--color-muted);
	}

	.section-link {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		color: var(--color-accent);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.section-link:hover {
		color: var(--color-accent-hover);
	}

	.articles-list {
		display: flex;
		flex-direction: column;
	}

	.article-row {
		display: grid;
		grid-template-columns: 3.5rem 7.5rem 6rem 1fr 4rem;
		align-items: baseline;
		gap: var(--spacing-4);
		padding: var(--spacing-4) var(--spacing-2);
		border-bottom: 1px solid var(--color-border-subtle);
		text-decoration: none;
		color: inherit;
		transition: background var(--transition-fast);
		border-radius: var(--radius);
	}

	.article-row:last-child {
		border-bottom: none;
	}

	.article-row:hover {
		background: color-mix(in srgb, var(--color-accent) 6%, transparent);
	}

	.article-row:hover .article-title-col {
		color: var(--color-accent);
	}

	.article-num {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-muted);
		white-space: nowrap;
	}

	.article-date-mono {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-muted);
		white-space: nowrap;
	}

	.article-cat {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
		color: var(--color-amber);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.article-title-col {
		font-size: var(--font-size-base);
		font-weight: 500;
		line-height: var(--leading-snug);
		color: var(--color-text);
		transition: color var(--transition-fast);
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.article-time {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-muted);
		text-align: right;
		white-space: nowrap;
	}

	.see-all-row {
		padding-top: var(--spacing-8);
	}

	.see-all-link {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		color: var(--color-accent);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.see-all-link:hover {
		color: var(--color-accent-hover);
	}

	/* ── Empty state ── */
	.empty-state {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--spacing-4);
		text-align: center;
		padding: var(--spacing-24) var(--spacing-6);
		font-family: var(--font-sans);
		color: var(--color-muted);
	}

	/* ── Responsive ── */
	@media (max-width: 860px) {
		.hero-inner {
			flex-direction: column-reverse;
			gap: var(--spacing-8);
		}

		.hero-portrait {
			padding-top: 0;
			flex-direction: row;
			align-items: center;
			gap: var(--spacing-5);
		}

		.portrait-frame {
			width: 100px;
			height: 100px;
		}
	}

	@media (max-width: 900px) {
		.article-row {
			grid-template-columns: 3rem 1fr auto;
			grid-template-rows: auto auto;
		}

		.article-num { grid-row: 1; grid-column: 1; }
		.article-title-col { grid-row: 1; grid-column: 2 / 4; white-space: normal; }
		.article-date-mono { grid-row: 2; grid-column: 2; }
		.article-cat { grid-row: 2; grid-column: 3; }
		.article-time { display: none; }
	}

	@media (max-width: 700px) {
		.info-inner { grid-template-columns: 1fr; }
		.info-col:first-child { border-right: none; border-bottom: 1px solid var(--color-border-subtle); }
	}

	@media (max-width: 600px) {
		.hero { padding: var(--spacing-10) var(--spacing-4) var(--spacing-10); }
		.info-col { padding: var(--spacing-8) var(--spacing-4); }
		.content-area { padding: var(--spacing-10) var(--spacing-4) var(--spacing-16); }
		.featured-card-inner { padding: var(--spacing-6); }

		.article-row {
			grid-template-columns: 2.5rem 1fr;
			gap: var(--spacing-2) var(--spacing-3);
		}

		.article-date-mono,
		.article-cat,
		.article-time { display: none; }

		.article-title-col { grid-column: 2; white-space: normal; }
	}
</style>
